cd /home/phoenixt/projects/lmforge/repo/lmforge/scripts/util

# ── state / audit ────────────────────────────────────────────────────────────
./dev_status.sh

# ── core: clean-rebuild-init-start (one shot) ────────────────────────────────
./dev-clean-reinstall-core_linux-sglang-cuda13.sh                       # full: wipe → rebuild → init → start
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --pull qwen3:1.7b:4bit  # also pulls a smoke model
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --keep-engines        # skip ~5 min engine reinstall
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --no-cargo-clean      # incremental rust build
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --no-init --no-start  # just rebuild + symlink
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --release             # release profile
./dev-clean-reinstall-core_linux-sglang-cuda13.sh --wipe-models         # also nuke ~/.lmforge/models

# ── UI: clean-reinstall-launch (one shot) ────────────────────────────────────
./dev-clean-reinstall-ui.sh                              # auto-detect distro → wipe ui artefacts → npm ci → tauri dev
./dev-clean-reinstall-ui.sh --build                      # AppImage build instead of `tauri dev`
./dev-clean-reinstall-ui.sh --keep-node --keep-rust      # iterate fast (only stop+launch)
./dev-clean-reinstall-ui.sh --no-launch                  # just clean + npm ci, don't run
./dev-clean-reinstall-ui.sh --distro fedora              # force distro variant

# ── UI: distro-specific launchers (called by the combo script too) ──────────
./dev_ui_ubuntu24.sh                # apt-based (Ubuntu / Debian / Mint)
./dev_ui_fedora.sh                  # dnf-based (Fedora / RHEL / Rocky / Alma)
./dev_ui_arch.sh                    # pacman-based (Arch / Manjaro / EndeavourOS)
./dev_ui_ubuntu24.sh --build        # any of the above accept --build (AppImage)
./dev_ui_ubuntu24.sh --skip-deps    # skip webkit/appindicator probe (faster restart)
./dev_ui_ubuntu24.sh --skip-daemon-check  # launch even if no daemon on :11430

# ── catalog (after `lmforge init` / dev rebuild) ─────────────────────────────
lmforge catalog                       # uses host's current engine format (GGUF on most boxes post-Phase 1)
lmforge catalog --format mlx          # Apple Silicon — omlx
lmforge catalog --format gguf         # Linux/Windows/CPU/low-VRAM — llamacpp (DEFAULT for everyone except Apple)
lmforge catalog --format safetensors  # opt-in: vLLM / SGLang (--engine flag)
lmforge catalog --format gguf --search qwen3.5
lmforge catalog --format safetensors --search embed
lmforge pull qwen3:1.7b:4bit                # uses current engine's catalog (GGUF unless --engine flips it)
lmforge pull unsloth/Qwen3-8B-GGUF          # direct HF repo (escape hatch if no shortcut)

# ── engine tier overrides (Phase 5.1) ────────────────────────────────────────
lmforge start                                       # auto-selects llamacpp on every non-Apple host
lmforge start --engine vllm  --model qwen3:8b:4bit  # opt-in tier (requires safetensors catalog)
lmforge start --engine sglang --yes-experimental    # experimental: known-broken on sm_120; needs explicit opt-in
LMFORGE_YES_EXPERIMENTAL=1 lmforge start --engine sglang   # same, for systemd/scripts

# ── tests ────────────────────────────────────────────────────────────────────
./dev_test.sh                          # ~17 s, cargo only
./dev_test.sh --with-e2e               # ~3 min first time, ~30 s after
./dev_test.sh --e2e-only --keep-daemon # iterate e2e against running daemon
./dev_test.sh --e2e-model qwen3:4b:4bit  # override default test model

# ── load / bench ─────────────────────────────────────────────────────────────
./dev_bench.sh -n 50 -c 8 --csv /tmp/bench.csv
./dev_bench.sh --stream --max-tokens 256
./dev_bench.sh -m qwen3:8b:4bit -n 100 -c 16

# ── logs (in another terminal) ───────────────────────────────────────────────
./dev_logs.sh                          # default dev.log
./dev_logs.sh --daemon                 # daemon out+err split
./dev_logs.sh --filter ERROR           # only errors, colored
./dev_logs.sh --all                    # everything in ~/.lmforge/logs/

# ── pre-commit safety ────────────────────────────────────────────────────────
./pre-commit-check-catalog.sh                  # full: JSON + drift + gated probe (safetensors+gguf) + quant suffix
./pre-commit-check-catalog.sh --no-network     # offline-only (JSON + drift + suffix)
./pre-commit-check-catalog.sh --fix-drift      # auto-resolve repo→live drift

# ── cleanup (audit by default; --yes to skip prompts) ────────────────────────
./dev_clean.sh                         # audit only (dry-run)
./dev_clean.sh --target --yes          # cargo + ui rust target (~3–6 GB)
./dev_clean.sh --node --yes            # ui/node_modules + ui/dist + .svelte-kit
./dev_clean.sh --engines --yes         # ~/.lmforge/{engines,bin}  (re-init: ~5 min)
./dev_clean.sh --logs --yes            # truncate ~/.lmforge/logs/*
./dev_clean.sh --engines --logs --yes  # frees ~8.6 GB, keeps models
./dev_clean.sh --all --yes             # everything except models + HF cache
./dev_clean.sh --models                # ALWAYS prompts (forces re-pull)
./dev_clean.sh --hf-cache              # ALWAYS prompts (shared with all HF tools)
./dev_clean.sh --nuke                  # full wipe (always prompts)

# ── in-binary cleanup (complements dev_clean.sh) ─────────────────────────────
lmforge clean                          # audit only
lmforge clean --target --yes           # cargo target via the binary
lmforge clean --engines --yes          # ~/.lmforge/engines (same effect)

# ── Cursor-sandbox stale-binary workaround (if cargo build looks ignored) ────
# Cursor's sandboxed shells redirect target/ writes to /tmp/cursor-sandbox-cache.
# Manually copy the fresh binary back if you suspect a stale ~/.cargo/bin/lmforge:
ls /tmp/cursor-sandbox-cache/*/target/debug/lmforge 2>/dev/null
