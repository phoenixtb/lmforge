# Copy to scripts/llamacpp-cuda/config.env (gitignored) and fill in values.
# Used by publish-r2.sh and update-manifest.sh.

# Public CDN base — create a subdomain in Cloudflare (see docs/engineering/R2-ENGINE-ASSETS.md)
# Example: https://engines.yourdomain.com
export LMFORGE_ENGINE_CDN_BASE="https://engines.YOURDOMAIN.com"

# R2 S3-compatible API (Cloudflare dashboard → R2 → bucket → S3 API)
export R2_ACCOUNT_ID="b6d9a834cd87e72e474ed65bd4f3c2e9"
export R2_BUCKET="lmforge-engine-assets"
export R2_ENDPOINT="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"

# R2 API token with Object Read & Write on this bucket only (NOT in git)
export R2_ACCESS_KEY_ID=""
export R2_SECRET_ACCESS_KEY=""

# Optional: llama.cpp tag for object_key paths (default parsed from tarball name)
# export LMFORGE_LLAMACPP_TAG="b9351"
