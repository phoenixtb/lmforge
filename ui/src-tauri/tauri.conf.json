{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LMForge",
  "version": "0.1.0",
  "identifier": "com.lmforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 960,
        "height": 660,
        "minWidth": 780,
        "minHeight": 540,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "visible": false,
        "resizable": true,
        "center": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
