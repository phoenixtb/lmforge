<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    LSUIElement = 1  →  NSApplicationActivationPolicyAccessory
    This is required for tray-first apps that start with no visible window.
    Without this key, NSApplication panics in did_finish_launching when
    visible:false is set and no Dock icon policy is explicitly declared.

    Effect:
      - No Dock icon (the app lives purely in the menu bar)
      - Window can still be shown/hidden programmatically via AppHandle
      - Cmd+Tab does not show the app
      - This is the standard pattern for menu-bar utilities (e.g. Bartender, Amphetamine)
  -->
  <key>LSUIElement</key>
  <true/>
</dict>
</plist>
